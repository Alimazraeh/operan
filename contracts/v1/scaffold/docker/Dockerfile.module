# Operan ADOS — Dockerfile Template
# Generated by ARCH (Platform Architect & Contract Manager)
# Usage: Copy to module directory and customize BUILD_ARGS

# =============================================================================
# ARCH STANDARD DOCKERFILE TEMPLATE
# =============================================================================
# - Multi-stage build for minimal image size
# - Non-root user by default
# - Health check included
# - Kubernetes-compatible
# =============================================================================

# ---- Stage 1: Build ----
FROM golang:1.22-alpine AS builder

ARG MODULE_NAME
ARG MODULE_VERSION
ARG BUILD_ARGS=""

RUN apk add --no-cache git ca-certificates

WORKDIR /build

# Copy go module files first (cache layer)
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build with version info
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-X main.version=${MODULE_VERSION} -X main.module=${MODULE_NAME}" \
    -o /build/${MODULE_NAME} ${BUILD_ARGS}

# ---- Stage 2: Runtime ----
FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata && \
    addgroup -S appgroup && \
    adduser -S appuser -G appgroup

WORKDIR /app

# Copy binary from builder
COPY --from=builder /build/${MODULE_NAME} /app/${MODULE_NAME}

# Copy contracts
COPY contracts/v1 /app/contracts/v1

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

# Non-root user
USER appuser

# Expose ports
EXPOSE 8080
EXPOSE 5672

# Environment variables (overridden by Kubernetes configmap/secret)
ENV MODULE_NAME=${MODULE_NAME} \
    MODULE_VERSION=${MODULE_VERSION} \
    LOG_LEVEL=info \
    OTEL_ENABLED=true

# Entry point
ENTRYPOINT ["/app/${MODULE_NAME}"]
CMD ["--config", "/app/config.yaml"]
