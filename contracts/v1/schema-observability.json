{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Observability & Telemetry Schema (Module 11)",
  "description": "Real-time monitoring and analytics. Metrics collection, distributed tracing, log aggregation, dashboard management, anomaly detection, and alerting.",
  "type": "object",
  "definitions": {
    "MetricPoint": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number", "format": "float" },
        "unit": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CreateDashboardRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "widgets"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "widgets": {
          "type": "array",
          "items": { "$ref": "#/definitions/DashboardWidget" }
        },
        "refresh_interval": { "type": "string" },
        "layout": { "type": "object" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "DashboardWidget": {
      "type": "object",
      "required": ["title", "type", "query"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["gauge", "line", "bar", "table", "trend", "heatmap"]
        },
        "query": { "$ref": "#/definitions/MetricQuery" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "w": { "type": "integer" },
            "h": { "type": "integer" }
          }
        },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "number" },
              "color": {
                "type": "string",
                "enum": ["green", "yellow", "red", "orange"]
              }
            }
          }
        }
      }
    },
    "MetricQuery": {
      "type": "object",
      "required": ["metric_name"],
      "properties": {
        "metric_name": { "type": "string" },
        "aggregation": {
          "type": "string",
          "enum": ["avg", "sum", "min", "max", "count", "rate", "percentile"]
        },
        "percentile": { "type": "integer" },
        "group_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "time_interval": { "type": "string" },
        "filters": { "type": "object" }
      }
    },
    "UpdateDashboardRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "widgets": {
          "type": "array",
          "items": { "$ref": "#/definitions/DashboardWidget" }
        },
        "refresh_interval": { "type": "string" },
        "layout": { "type": "object" }
      }
    },
    "TraceSpan": {
      "type": "object",
      "required": ["trace_id", "span_id", "operation", "start_time", "duration_ms"],
      "properties": {
        "trace_id": { "type": "string", "format": "uuid" },
        "span_id": { "type": "string", "format": "uuid" },
        "parent_span_id": { "type": "string", "format": "uuid" },
        "operation": { "type": "string" },
        "service": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["ok", "error", "cancelled"]
        },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/TraceEvent" }
        },
        "error": { "$ref": "#/definitions/SpanError" }
      }
    },
    "TraceEvent": {
      "type": "object",
      "required": ["name", "timestamp"],
      "properties": {
        "name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "attributes": { "type": "object" }
      }
    },
    "SpanError": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "code": { "type": "integer" },
        "stack_trace": { "type": "string" }
      }
    },
    "LogEntry": {
      "type": "object",
      "required": ["message", "level", "timestamp"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "service": { "type": "string" },
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error", "critical"]
        },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "module": { "type": "string" },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "context": { "type": "object" },
        "trace_id": { "type": "string", "format": "uuid" },
        "span_id": { "type": "string", "format": "uuid" }
      }
    },
    "Anomaly": {
      "type": "object",
      "required": ["id", "metric_name", "severity", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "metric_name": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "acknowledged", "resolved"]
        },
        "detected_at": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "expected_value": { "type": "number" },
        "actual_value": { "type": "number" },
        "deviation": { "type": "number" },
        "related_spans": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        },
        "resolved_at": { "type": "string", "format": "date-time" },
        "resolved_by": { "type": "string", "format": "uuid" }
      }
    },
    "CreateAlertRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "condition"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "condition": { "$ref": "#/definitions/AlertCondition" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/AlertAction" }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["email", "slack", "webhooks", "pagerduty"]
          }
        },
        "enabled": { "type": "boolean", "default": true },
        "cooldown": { "type": "string" }
      }
    },
    "UpdateAlertRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "condition": { "$ref": "#/definitions/AlertCondition" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/AlertAction" }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["email", "slack", "webhooks", "pagerduty"]
          }
        },
        "enabled": { "type": "boolean" },
        "cooldown": { "type": "string" }
      }
    },
    "AlertCondition": {
      "type": "object",
      "required": ["metric", "operator", "threshold"],
      "properties": {
        "metric": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": ["gt", "gte", "lt", "lte", "eq", "neq", "above_rate", "below_rate"]
        },
        "threshold": { "type": "number" },
        "duration": { "type": "string" },
        "condition": { "type": "string" }
      }
    },
    "AlertAction": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["notify", "escalate", "trigger_workflow", "auto_remediation"]
        },
        "parameters": { "type": "object" }
      }
    },
    "HealthStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy"]
        },
        "uptime_seconds": { "type": "integer" },
        "components": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["healthy", "degraded", "unhealthy"]
          }
        },
        "last_check": { "type": "string", "format": "date-time" }
      }
    },
    "TelemetryStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy"]
        },
        "ingestion_rate": { "type": "integer" },
        "storage_usage_percent": { "type": "number" },
        "active_dashboards": { "type": "integer" },
        "active_alerts": { "type": "integer" },
        "last_ingestion": { "type": "string", "format": "date-time" },
        "queue_depth": { "type": "integer" }
      }
    }
  }
}
