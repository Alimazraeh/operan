{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Arabic Language Intelligence Layer Schema (Module 19)",
  "description": "Arabic-first NLP capabilities including embeddings, terminology governance, dialect normalization, OCR, semantic retrieval, and translation memory.",
  "type": "object",
  "definitions": {
    "GenerateArabicEmbeddingsRequest": {
      "type": "object",
      "required": ["tenant_id", "texts"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "texts": { "type": "array", "items": { "type": "string" } },
        "model": { "type": "string", "default": "arabic-embeddings-v1" },
        "normalize_dialect": { "type": "boolean", "default": false },
        "metadata": { "type": "object" }
      }
    },
    "ArabicEmbedding": {
      "type": "object",
      "required": ["id", "model"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "model": { "type": "string" },
        "texts": { "type": "array", "items": { "type": "object" } },
        "embedding_dimensions": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "CreateTerminologyEntryRequest": {
      "type": "object",
      "required": ["tenant_id", "term"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "term": { "type": "string" },
        "translation": { "type": "string" },
        "definition": { "type": "string" },
        "category": { "type": "string" },
        "source_language": { "type": "string", "default": "ar" },
        "target_language": { "type": "string" },
        "domain": { "type": "string" },
        "usage_examples": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "metadata": { "type": "object" }
      }
    },
    "TerminologyEntry": {
      "type": "object",
      "required": ["id", "term"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "term": { "type": "string" },
        "translation": { "type": "string" },
        "definition": { "type": "string" },
        "category": { "type": "string" },
        "source_language": { "type": "string" },
        "target_language": { "type": "string" },
        "domain": { "type": "string" },
        "usage_examples": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "UpdateTerminologyEntryRequest": {
      "type": "object",
      "properties": {
        "term": { "type": "string" },
        "translation": { "type": "string" },
        "definition": { "type": "string" },
        "category": { "type": "string" },
        "domain": { "type": "string" },
        "usage_examples": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "metadata": { "type": "object" }
      }
    },
    "SearchTerminologyRequest": {
      "type": "object",
      "required": ["tenant_id", "query"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "query": { "type": "string" },
        "category": { "type": "string" },
        "domain": { "type": "string" },
        "language_code": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "limit": { "type": "integer", "default": 20 },
        "offset": { "type": "integer", "default": 0 }
      }
    },
    "DialectNormalizationRequest": {
      "type": "object",
      "required": ["tenant_id", "texts"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "texts": { "type": "array", "items": { "type": "string" } },
        "source_dialect": { "type": "string" },
        "target_dialect": { "type": "string", "default": "MSA" },
        "preserve_formatting": { "type": "boolean", "default": true }
      }
    },
    "DialectNormalizationResult": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": { "type": "string" },
        "output": { "type": "string" },
        "source_dialect": { "type": "string" },
        "target_dialect": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },
    "CreateNormalizationRuleRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "rules"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "object" } },
        "source_dialect": { "type": "string" },
        "target_dialect": { "type": "string", "default": "MSA" },
        "metadata": { "type": "object" }
      }
    },
    "NormalizationRule": {
      "type": "object",
      "required": ["id", "name", "rules"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "object" } },
        "source_dialect": { "type": "string" },
        "target_dialect": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "UpdateNormalizationRuleRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "metadata": { "type": "object" }
      }
    },
    "ArabicOCRRequest": {
      "type": "object",
      "required": ["tenant_id", "image"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "image": { "type": "string", "format": "byte" },
        "image_url": { "type": "string" },
        "language": { "type": "string", "default": "ar" },
        "output_format": { "type": "string", "enum": ["text", "json", "hocr"] },
        "preprocess": { "type": "boolean", "default": true }
      }
    },
    "ArabicOCRResult": {
      "type": "object",
      "required": ["id", "tenant_id", "text"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "text": { "type": "string" },
        "confidence": { "type": "number" },
        "language": { "type": "string" },
        "words": { "type": "array", "items": { "type": "object" } },
        "pages": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
        "error_message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "SemanticSearchRequest": {
      "type": "object",
      "required": ["tenant_id", "query"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "query": { "type": "string" },
        "collection": { "type": "string" },
        "top_k": { "type": "integer", "default": 10 },
        "min_score": { "type": "number", "default": 0.7 },
        "filters": { "type": "object" },
        "metadata": { "type": "object" }
      }
    },
    "SemanticSearchResult": {
      "type": "object",
      "required": ["query", "results"],
      "properties": {
        "query": { "type": "string" },
        "results": { "type": "array", "items": { "type": "object" } },
        "query_embedding": { "type": "array", "items": { "type": "number" } },
        "total_results": { "type": "integer" }
      }
    },
    "CreateTranslationMemoryEntryRequest": {
      "type": "object",
      "required": ["tenant_id", "source_text", "target_text", "source_lang", "target_lang"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "source_text": { "type": "string" },
        "target_text": { "type": "string" },
        "source_lang": { "type": "string" },
        "target_lang": { "type": "string" },
        "domain": { "type": "string" },
        "context": { "type": "string" },
        "quality_score": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "metadata": { "type": "object" }
      }
    },
    "TranslationMemoryEntry": {
      "type": "object",
      "required": ["id", "source_text", "target_text"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "source_text": { "type": "string" },
        "target_text": { "type": "string" },
        "source_lang": { "type": "string" },
        "target_lang": { "type": "string" },
        "domain": { "type": "string" },
        "context": { "type": "string" },
        "quality_score": { "type": "number" },
        "usage_count": { "type": "integer" },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "UpdateTranslationMemoryEntryRequest": {
      "type": "object",
      "properties": {
        "source_text": { "type": "string" },
        "target_text": { "type": "string" },
        "domain": { "type": "string" },
        "context": { "type": "string" },
        "quality_score": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "approved", "deprecated"] },
        "metadata": { "type": "object" }
      }
    },
    "SearchTranslationMemoryRequest": {
      "type": "object",
      "required": ["tenant_id", "source_text"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "source_text": { "type": "string" },
        "source_lang": { "type": "string" },
        "target_lang": { "type": "string" },
        "domain": { "type": "string" },
        "top_k": { "type": "integer", "default": 5 },
        "min_similarity": { "type": "number", "default": 0.5 }
      }
    },
    "HealthStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["healthy", "degraded", "unhealthy"] },
        "uptime_seconds": { "type": "integer" },
        "active_embeddings": { "type": "integer" },
        "active_ocr_jobs": { "type": "integer" },
        "terminology_entries": { "type": "integer" },
        "translation_memory_entries": { "type": "integer" },
        "last_check": { "type": "string", "format": "date-time" }
      }
    }
  }
}
