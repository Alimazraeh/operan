{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.operan.dev/v1/cost-governance-engine.json",
  "title": "Operan Cost Governance Engine JSON Schema",
  "description": "Comprehensive JSON Schema for the Cost Governance Engine module covering budgets, throttles, forecasts, billing, and usage domain objects.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "budget_type": {
      "$ref": "#/$defs/BudgetType"
    },
    "budget_period": {
      "$ref": "#/$defs/BudgetPeriod"
    },
    "budget_status": {
      "$ref": "#/$defs/BudgetStatus"
    },
    "throttle_action": {
      "$ref": "#/$defs/ThrottleAction"
    },
    "create_budget_request": {
      "$ref": "#/$defs/CreateBudgetRequest"
    },
    "update_budget_request": {
      "$ref": "#/$defs/UpdateBudgetRequest"
    },
    "budget": {
      "$ref": "#/$defs/Budget"
    },
    "budget_evaluation": {
      "$ref": "#/$defs/BudgetEvaluation"
    },
    "budget_usage": {
      "$ref": "#/$defs/BudgetUsage"
    },
    "usage_breakdown": {
      "$ref": "#/$defs/UsageBreakdown"
    },
    "create_throttle_request": {
      "$ref": "#/$defs/CreateThrottleRequest"
    },
    "update_throttle_request": {
      "$ref": "#/$defs/UpdateThrottleRequest"
    },
    "throttle": {
      "$ref": "#/$defs/Throttle"
    },
    "create_forecast_request": {
      "$ref": "#/$defs/CreateForecastRequest"
    },
    "forecast": {
      "$ref": "#/$defs/Forecast"
    },
    "forecast_data_point": {
      "$ref": "#/$defs/ForecastDataPoint"
    },
    "generate_billing_request": {
      "$ref": "#/$defs/GenerateBillingRequest"
    },
    "tenant_billing": {
      "$ref": "#/$defs/TenantBilling"
    },
    "billing_line_item": {
      "$ref": "#/$defs/BillingLineItem"
    },
    "billing_generation": {
      "$ref": "#/$defs/BillingGeneration"
    },
    "usage_list": {
      "$ref": "#/$defs/UsageList"
    },
    "usage_record": {
      "$ref": "#/$defs/UsageRecord"
    },
    "problem_detail": {
      "$ref": "#/$defs/ProblemDetail"
    }
  },
  "$defs": {
    "BudgetType": {
      "type": "string",
      "enum": [
        "token_budget",
        "execution_budget",
        "agent_budget",
        "department_budget",
        "tenant_budget"
      ],
      "description": "Type of budget governing"
    },
    "BudgetPeriod": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "annually"
      ],
      "description": "Budget reset period"
    },
    "BudgetStatus": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "exceeded",
        "closed",
        "expired"
      ],
      "description": "Current state of the budget"
    },
    "ThrottleAction": {
      "type": "string",
      "enum": [
        "warn",
        "slow_down",
        "reject",
        "escalate"
      ],
      "description": "Action to take when threshold is triggered"
    },
    "CreateBudgetRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "name",
        "type",
        "limit",
        "period"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "description": "Tenant this budget belongs to"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Human-readable budget name"
        },
        "description": {
          "type": "string",
          "maxLength": 1024,
          "description": "Optional budget description"
        },
        "type": {
          "$ref": "#/$defs/BudgetType"
        },
        "limit": {
          "type": "number",
          "minimum": 0.01,
          "description": "Maximum allowed cost (in platform currency units)"
        },
        "warning_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.8,
          "description": "Percentage of budget at which warnings trigger"
        },
        "period": {
          "$ref": "#/$defs/BudgetPeriod"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional arbitrary metadata"
        },
        "created_by": {
          "type": "string",
          "format": "uuid",
          "description": "User ID of the budget creator"
        }
      },
      "additionalProperties": false
    },
    "UpdateBudgetRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "limit": {
          "type": "number",
          "minimum": 0.01
        },
        "warning_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "period": {
          "$ref": "#/$defs/BudgetPeriod"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "Budget": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "name",
        "type",
        "limit",
        "period",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/BudgetType"
        },
        "limit": {
          "type": "number"
        },
        "warning_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "period": {
          "$ref": "#/$defs/BudgetPeriod"
        },
        "status": {
          "$ref": "#/$defs/BudgetStatus"
        },
        "current_usage": {
          "type": "number",
          "description": "Current consumption against this budget"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "created_by": {
          "type": "string",
          "format": "uuid"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "BudgetEvaluation": {
      "type": "object",
      "required": [
        "budget_id",
        "status",
        "usage_percentage",
        "evaluated_at"
      ],
      "properties": {
        "budget_id": {
          "type": "string",
          "format": "uuid"
        },
        "status": {
          "type": "string",
          "enum": [
            "within_limit",
            "warning",
            "exceeded",
            "critical"
          ],
          "description": "Evaluation result"
        },
        "limit": {
          "type": "number"
        },
        "current_usage": {
          "type": "number"
        },
        "usage_percentage": {
          "type": "number",
          "minimum": 0
        },
        "remaining_budget": {
          "type": "number"
        },
        "warning_threshold": {
          "type": "number"
        },
        "throttle_actions_triggered": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "warn",
              "slow_down",
              "reject",
              "escalate"
            ]
          }
        },
        "evaluated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "BudgetUsage": {
      "type": "object",
      "required": [
        "budget_id",
        "total_usage",
        "breakdown"
      ],
      "properties": {
        "budget_id": {
          "type": "string",
          "format": "uuid"
        },
        "total_usage": {
          "type": "number"
        },
        "limit": {
          "type": "number"
        },
        "remaining": {
          "type": "number"
        },
        "usage_percentage": {
          "type": "number"
        },
        "breakdown": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/UsageBreakdown"
          }
        },
        "period_start": {
          "type": "string",
          "format": "date-time"
        },
        "period_end": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "UsageBreakdown": {
      "type": "object",
      "required": [
        "metric_type",
        "count",
        "cost"
      ],
      "properties": {
        "metric_type": {
          "type": "string",
          "enum": [
            "token",
            "execution",
            "agent"
          ],
          "description": "Type of usage metric"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "cost": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "CreateThrottleRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "budget_id",
        "action",
        "trigger_threshold"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "budget_id": {
          "type": "string",
          "format": "uuid",
          "description": "Budget this throttle applies to"
        },
        "action": {
          "$ref": "#/$defs/ThrottleAction"
        },
        "trigger_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Usage percentage at which to trigger this throttle"
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "created_by": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false
    },
    "UpdateThrottleRequest": {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/ThrottleAction"
        },
        "trigger_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "Throttle": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "budget_id",
        "action",
        "trigger_threshold",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "budget_id": {
          "type": "string",
          "format": "uuid"
        },
        "action": {
          "$ref": "#/$defs/ThrottleAction"
        },
        "trigger_threshold": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "disabled"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "created_by": {
          "type": "string",
          "format": "uuid"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "CreateForecastRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "forecast_period"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "forecast_period": {
          "$ref": "#/$defs/BudgetPeriod"
        },
        "budget_id": {
          "type": "string",
          "format": "uuid",
          "description": "Optional specific budget to forecast"
        },
        "module": {
          "type": "string",
          "description": "Optional module filter"
        },
        "confidence_interval": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.95,
          "description": "Confidence level for the forecast"
        },
        "trend_analysis": {
          "type": "object",
          "properties": {
            "lookback_periods": {
              "type": "integer",
              "minimum": 1,
              "default": 3,
              "description": "Number of historical periods to analyze"
            },
            "seasonality": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "Forecast": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "forecast_period",
        "projected_cost",
        "confidence_interval",
        "generated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "budget_id": {
          "type": "string",
          "format": "uuid"
        },
        "forecast_period": {
          "$ref": "#/$defs/BudgetPeriod"
        },
        "module": {
          "type": "string"
        },
        "projected_cost": {
          "type": "number",
          "description": "Projected total cost for the forecast period"
        },
        "projected_low": {
          "type": "number",
          "description": "Lower bound of confidence interval"
        },
        "projected_high": {
          "type": "number",
          "description": "Upper bound of confidence interval"
        },
        "confidence_interval": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "trend_data": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ForecastDataPoint"
          }
        },
        "methodology": {
          "type": "string",
          "description": "Description of forecasting methodology used"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ForecastDataPoint": {
      "type": "object",
      "properties": {
        "period": {
          "type": "string",
          "format": "date-time"
        },
        "historical_cost": {
          "type": "number"
        },
        "projected_cost": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "GenerateBillingRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "period"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "period": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$",
          "description": "Billing period in YYYY-MM format"
        },
        "include_tokens": {
          "type": "boolean",
          "default": true
        },
        "include_executions": {
          "type": "boolean",
          "default": true
        },
        "include_agents": {
          "type": "boolean",
          "default": true
        },
        "output_format": {
          "type": "string",
          "enum": [
            "summary",
            "detailed"
          ],
          "default": "detailed"
        }
      },
      "additionalProperties": false
    },
    "TenantBilling": {
      "type": "object",
      "required": [
        "tenant_id",
        "period",
        "total_charges",
        "generated_at"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "period": {
          "type": "string"
        },
        "total_charges": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "token_charges": {
          "type": "number"
        },
        "execution_charges": {
          "type": "number"
        },
        "agent_charges": {
          "type": "number"
        },
        "line_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BillingLineItem"
          }
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "BillingLineItem": {
      "type": "object",
      "required": [
        "metric_type",
        "quantity",
        "unit_cost",
        "total"
      ],
      "properties": {
        "metric_type": {
          "type": "string",
          "enum": [
            "token",
            "execution",
            "agent"
          ]
        },
        "resource_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the specific resource (module, agent, etc.)"
        },
        "resource_name": {
          "type": "string"
        },
        "quantity": {
          "type": "integer",
          "minimum": 0
        },
        "unit_cost": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "period_start": {
          "type": "string",
          "format": "date-time"
        },
        "period_end": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "BillingGeneration": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "status",
        "submitted_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "period": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "processing",
            "completed",
            "failed"
          ]
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "result_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to retrieve the completed billing report"
        }
      },
      "additionalProperties": false
    },
    "UsageList": {
      "type": "object",
      "required": [
        "items",
        "total",
        "cursor"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/UsageRecord"
          }
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "cursor": {
          "type": "string",
          "description": "Pagination cursor for next page"
        },
        "has_more": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "UsageRecord": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "metric_type",
        "count",
        "cost",
        "timestamp"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "module": {
          "type": "string"
        },
        "agent_id": {
          "type": "string",
          "format": "uuid"
        },
        "metric_type": {
          "type": "string",
          "enum": [
            "token",
            "execution",
            "agent"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "cost": {
          "type": "number",
          "minimum": 0
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ProblemDetail": {
      "type": "object",
      "required": [
        "type",
        "title",
        "status",
        "detail",
        "instance"
      ],
      "properties": {
        "type": {
          "type": "string",
          "format": "uri",
          "description": "Problem type URI"
        },
        "title": {
          "type": "string",
          "description": "Short error summary"
        },
        "status": {
          "type": "integer",
          "description": "HTTP status code"
        },
        "detail": {
          "type": "string",
          "description": "Human-readable error detail"
        },
        "instance": {
          "type": "string",
          "description": "URI reference to the specific request instance"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
