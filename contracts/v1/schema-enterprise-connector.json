{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Enterprise Connector Fabric Schema (Module 18)",
  "description": "Connect Operan to enterprise systems (SAP, Oracle, Salesforce, Microsoft 365, Google Workspace, ServiceNow, Slack, Teams, Jira, GitHub) with universal connectors, data mapping, and orchestration.",
  "type": "object",
  "definitions": {
    "RegisterConnectorRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "type"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["sap", "oracle", "salesforce", "microsoft365", "googleworkspace", "servicenow", "slack", "teams", "jira", "github"] },
        "auth_type": { "type": "string", "enum": ["oauth2", "api_key", "basic", "sso", "cert"] },
        "config": { "type": "object" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Connector": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["sap", "oracle", "salesforce", "microsoft365", "googleworkspace", "servicenow", "slack", "teams", "jira", "github"] },
        "auth_type": { "type": "string", "enum": ["oauth2", "api_key", "basic", "sso", "cert"] },
        "status": { "type": "string", "enum": ["active", "inactive", "error", "testing"] },
        "last_sync": { "type": "string", "format": "date-time" },
        "config": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "UpdateConnectorRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "config": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "inactive", "error", "testing"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ConnectorTestResult": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "message": { "type": "string" },
        "details": { "type": "object" },
        "latency_ms": { "type": "integer" }
      }
    },
    "ConnectorStatus": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["active", "inactive", "error", "testing"] },
        "connections": { "type": "integer" },
        "active_syncs": { "type": "integer" },
        "errors": { "type": "integer" },
        "last_error": { "type": "string" },
        "uptime": { "type": "string" }
      }
    },
    "TriggerSyncRequest": {
      "type": "object",
      "properties": {
        "sync_type": { "type": "string", "enum": ["full", "incremental"] },
        "entities": { "type": "array", "items": { "type": "string" } },
        "filters": { "type": "object" }
      }
    },
    "CreateConnectionRequest": {
      "type": "object",
      "required": ["tenant_id", "connector_id", "name"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "connector_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "endpoint": { "type": "string" },
        "credentials": { "type": "object" },
        "metadata": { "type": "object" }
      }
    },
    "Connection": {
      "type": "object",
      "required": ["id", "connector_id", "name"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "connector_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "endpoint": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "metadata": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "UpdateConnectionRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "endpoint": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "metadata": { "type": "object" }
      }
    },
    "CreateDataMappingRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "source", "target"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "connector_id": { "type": "string", "format": "uuid" },
        "source": {
          "type": "object",
          "required": ["entity", "fields"],
          "properties": {
            "entity": { "type": "string" },
            "fields": { "type": "object" }
          }
        },
        "target": {
          "type": "object",
          "required": ["entity", "fields"],
          "properties": {
            "entity": { "type": "string" },
            "fields": { "type": "object" }
          }
        },
        "transformations": { "type": "array", "items": { "type": "object" } },
        "metadata": { "type": "object" }
      }
    },
    "DataMapping": {
      "type": "object",
      "required": ["id", "name", "source", "target"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "connector_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "object" },
        "target": { "type": "object" },
        "transformations": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "UpdateDataMappingRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "object" },
        "target": { "type": "object" },
        "transformations": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "metadata": { "type": "object" }
      }
    },
    "CreateDataSyncRequest": {
      "type": "object",
      "required": ["tenant_id", "name"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "source_connector_id": { "type": "string", "format": "uuid" },
        "target_connector_id": { "type": "string", "format": "uuid" },
        "mapping_id": { "type": "string", "format": "uuid" },
        "schedule": { "type": "object" },
        "sync_type": { "type": "string", "enum": ["full", "incremental"] },
        "metadata": { "type": "object" }
      }
    },
    "DataSync": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "source_connector_id": { "type": "string", "format": "uuid" },
        "target_connector_id": { "type": "string", "format": "uuid" },
        "mapping_id": { "type": "string", "format": "uuid" },
        "schedule": { "type": "object" },
        "sync_type": { "type": "string", "enum": ["full", "incremental"] },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
        "records_synced": { "type": "integer" },
        "records_total": { "type": "integer" },
        "error_message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "DataSyncLog": {
      "type": "object",
      "required": ["timestamp", "level"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "sync_id": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "CreateOrchestrationRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "steps"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["order", "connector_id"],
            "properties": {
              "order": { "type": "integer" },
              "connector_id": { "type": "string", "format": "uuid" },
              "action": { "type": "string" },
              "mapping_id": { "type": "string", "format": "uuid" },
              "condition": { "type": "object" }
            }
          }
        },
        "trigger": { "type": "object" },
        "metadata": { "type": "object" }
      }
    },
    "Orchestration": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "object" } },
        "trigger": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "inactive", "paused", "error"] },
        "last_run": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "UpdateOrchestrationRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "object" } },
        "trigger": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "inactive", "paused", "error"] },
        "metadata": { "type": "object" }
      }
    },
    "OrchestrationRun": {
      "type": "object",
      "required": ["id", "orchestration_id"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "orchestration_id": { "type": "string", "format": "uuid" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["running", "completed", "failed", "cancelled"] },
        "steps_completed": { "type": "integer" },
        "steps_total": { "type": "integer" },
        "error_message": { "type": "string" }
      }
    },
    "HealthStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["healthy", "degraded", "unhealthy"] },
        "uptime_seconds": { "type": "integer" },
        "active_connectors": { "type": "integer" },
        "active_syncs": { "type": "integer" },
        "active_orchestrations": { "type": "integer" },
        "last_check": { "type": "string", "format": "date-time" }
      }
    }
  }
}
