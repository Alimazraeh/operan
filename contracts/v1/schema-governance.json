{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Policy & Governance Engine Schema (Module 10)",
  "description": "Enterprise compliance and control. Policy definitions, rules, evaluations, compliance audits, and risk scoring.",
  "type": "object",
  "definitions": {
    "CreatePolicyRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "description"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["financial", "hr", "data", "security", "compliance", "operational", "legal"]
        },
        "scope": { "type": "object", "description": "Policy scope (tenant, department, agent types)" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/CreateRuleRequest" }
        },
        "enforcement_level": {
          "type": "string",
          "enum": ["strict", "advisory", "experimental"]
        },
        "version": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Policy": {
      "type": "object",
      "required": ["id", "name", "category", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "scope": { "type": "object" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/Rule" }
        },
        "enforcement_level": {
          "type": "string",
          "enum": ["strict", "advisory", "experimental"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "draft", "deprecated", "suspended"]
        },
        "version": { "type": "string" },
        "created_by": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CreateRuleRequest": {
      "type": "object",
      "required": ["name", "condition", "effect"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "condition": {
          "type": "string",
          "description": "Policy condition (Rego or structured format)"
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny", "require_approval", "log", "throttle", "rate_limit"]
        },
        "priority": { "type": "integer", "default": 0 },
        "parameters": { "type": "object" },
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "Rule": {
      "type": "object",
      "required": ["id", "name", "condition", "effect"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "policy_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "condition": { "type": "string" },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny", "require_approval", "log", "throttle", "rate_limit"]
        },
        "priority": { "type": "integer" },
        "parameters": { "type": "object" },
        "enabled": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "EvaluationRequest": {
      "type": "object",
      "required": ["action", "actor", "resource"],
      "properties": {
        "action": {
          "type": "string",
          "description": "The action being evaluated (e.g., 'create_payment', 'sign_contract')"
        },
        "actor": { "type": "string", "format": "uuid" },
        "resource": { "type": "string", "format": "uuid" },
        "context": {
          "type": "object",
          "description": "Additional context for evaluation (amount, data sensitivity, etc.)"
        },
        "environment": {
          "type": "object",
          "description": "Environment metadata (department, workflow, etc.)"
        }
      }
    },
    "PolicyEvaluation": {
      "type": "object",
      "required": ["allowed", "policy_id", "rules_evaluated"],
      "properties": {
        "allowed": { "type": "boolean" },
        "policy_id": { "type": "string", "format": "uuid" },
        "rules_evaluated": { "type": "integer" },
        "violated_rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/ViolatedRule" }
        },
        "requires_approval": { "type": "boolean" },
        "approval_chain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "throttling": { "$ref": "#/definitions/ThrottleConfig" },
        "decision_rationale": { "type": "string" },
        "evaluation_time_ms": { "type": "integer" }
      }
    },
    "ViolatedRule": {
      "type": "object",
      "required": ["rule_id", "rule_name", "effect"],
      "properties": {
        "rule_id": { "type": "string", "format": "uuid" },
        "rule_name": { "type": "string" },
        "effect": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "ThrottleConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "rate_limit": { "type": "integer" },
        "window_seconds": { "type": "integer" },
        "burst_limit": { "type": "integer" }
      }
    },
    "PolicyValidation": {
      "type": "object",
      "required": ["valid"],
      "properties": {
        "valid": { "type": "boolean" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "syntax_check": { "type": "boolean" },
        "logic_check": { "type": "boolean" },
        "conflict_check": { "type": "boolean" },
        "conflicts": {
          "type": "array",
          "items": { "$ref": "#/definitions/PolicyConflict" }
        }
      }
    },
    "PolicyConflict": {
      "type": "object",
      "required": ["rule_id_1", "rule_id_2", "conflict_type"],
      "properties": {
        "rule_id_1": { "type": "string", "format": "uuid" },
        "rule_id_2": { "type": "string", "format": "uuid" },
        "conflict_type": {
          "type": "string",
          "enum": ["contradiction", "shadow", "redundancy"]
        },
        "description": { "type": "string" }
      }
    },
    "ComplianceAudit": {
      "type": "object",
      "required": ["id", "status", "auditor_id"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "auditor_id": { "type": "string", "format": "uuid" },
        "scope": { "type": "string" },
        "scope_id": { "type": "string", "format": "uuid" },
        "criteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed"]
        },
        "results": { "type": "object" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/definitions/AuditFinding" }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "AuditFinding": {
      "type": "object",
      "required": ["category", "severity", "status"],
      "properties": {
        "category": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "informational"]
        },
        "description": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "status": {
          "type": "string",
          "enum": ["open", "acknowledged", "remediated", "accepted", "false_positive"]
        },
        "remediation": { "type": "string" },
        "assigned_to": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "resolved_at": { "type": "string", "format": "date-time" }
      }
    },
    "RiskScores": {
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "overall_risk_score": {
          "type": "number",
          "format": "float",
          "minimum": 0,
          "maximum": 10
        },
        "categories": {
          "type": "object",
          "properties": {
            "execution_risk": { "$ref": "#/definitions/RiskScoreDetail" },
            "compliance_risk": { "$ref": "#/definitions/RiskScoreDetail" },
            "data_risk": { "$ref": "#/definitions/RiskScoreDetail" },
            "financial_risk": { "$ref": "#/definitions/RiskScoreDetail" },
            "operational_risk": { "$ref": "#/definitions/RiskScoreDetail" }
          }
        }
      }
    },
    "RiskScoreDetail": {
      "type": "object",
      "required": ["score", "level"],
      "properties": {
        "score": {
          "type": "number",
          "format": "float",
          "minimum": 0,
          "maximum": 10
        },
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "trends": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "score": { "type": "number" }
            }
          }
        },
        "contributing_factors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    }
  }
}
