{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Tool Execution Layer Schema (Module 08)",
  "description": "Secure external action execution engine — API execution, browser automation, ERP interaction, email, document generation, workflow triggering with sandboxing, dry-run, and rollback support.",
  "type": "object",
  "definitions": {
    "ToolDefinition": {
      "type": "object",
      "required": ["id", "name", "capability"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "capability": {
          "type": "string",
          "enum": [
            "api_execution", "browser_automation", "erp_interaction",
            "email", "document_generation", "workflow_trigger",
            "file_system", "database_query", "webhook"
          ]
        },
        "description": { "type": "string" },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "requires_sandbox": { "type": "boolean" },
        "sandbox_isolation_level": {
          "type": "string",
          "enum": ["container", "namespace", "process"]
        },
        "execution_timeout_seconds": { "type": "integer" },
        "cost_model": {
          "type": "string",
          "enum": ["free", "per_execution", "per_token", "usage_based"]
        },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "version": { "type": "string" },
        "is_internal": { "type": "boolean" }
      }
    },
    "ToolExecutionRequest": {
      "type": "object",
      "required": ["tenant_id", "agent_id", "tool_id", "input"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "agent_id": { "type": "string", "format": "uuid" },
        "tool_id": { "type": "string", "format": "uuid" },
        "input": { "type": "object" },
        "sandbox_id": { "type": "string", "format": "uuid" },
        "dry_run": { "type": "boolean", "default": false },
        "timeout_seconds": { "type": "integer" },
        "max_retries": { "type": "integer", "default": 0 },
        "policy_check": { "type": "boolean", "default": true }
      }
    },
    "ToolExecutionResult": {
      "type": "object",
      "required": ["id", "status", "tool_id"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": ["queued", "running", "completed", "failed", "rollback", "dry_run"]
        },
        "tool_id": { "type": "string", "format": "uuid" },
        "tool_name": { "type": "string" },
        "input": { "type": "object" },
        "output": { "type": "object" },
        "error": { "type": "string" },
        "policy_validation": { "type": "object" },
        "rollback_available": { "type": "boolean" },
        "rollback_id": { "type": "string", "format": "uuid" },
        "sandbox_id": { "type": "string", "format": "uuid" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "execution_time_ms": { "type": "integer" }
      }
    },
    "Sandbox": {
      "type": "object",
      "required": ["id", "tenant_id", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "agent_id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": ["initializing", "ready", "running", "expired", "destroyed"]
        },
        "isolation_level": {
          "type": "string",
          "enum": ["container", "namespace", "process"]
        },
        "network_restricted": { "type": "boolean" },
        "resource_quota": {
          "type": "object",
          "properties": {
            "cpu_cores": { "type": "number" },
            "memory_mb": { "type": "integer" },
            "disk_mb": { "type": "integer" },
            "network_bandwidth_mbps": { "type": "integer" },
            "process_limit": { "type": "integer" }
          }
        },
        "container_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "PolicyCheckResult": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": { "type": "boolean" },
        "policy_id": { "type": "string" },
        "rules_evaluated": { "type": "integer" },
        "deny_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires_approval": { "type": "boolean" },
        "approval_chain": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "DryRunResult": {
      "type": "object",
      "required": ["tool_id", "predicted_impact"],
      "properties": {
        "tool_id": { "type": "string", "format": "uuid" },
        "predicted_impact": {
          "type": "string",
          "enum": ["read_only", "safe_write", "risky", "destructive"]
        },
        "side_effects": { "type": "array", "items": { "type": "string" } },
        "estimated_cost": { "type": "object" },
        "policy_warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
