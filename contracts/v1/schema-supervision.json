{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Human Supervision Layer Schema (Module 09)",
  "description": "Govern autonomous execution safely — approvals, escalations, interventions, override controls, and human-in-the-loop review.",
  "type": "object",
  "definitions": {
    "ApprovalRequest": {
      "type": "object",
      "required": ["id", "requester_id", "status", "approval_model"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "requester_id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "action_type": { "type": "string" },
        "target_resource": { "type": "string", "format": "uuid" },
        "target_type": {
          "type": "string",
          "enum": ["agent", "department", "workflow", "system"]
        },
        "approval_model": {
          "type": "string",
          "enum": ["sequential", "parallel", "conditional", "threshold"]
        },
        "approvers": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        },
        "approval_chain": {
          "type": "array",
          "items": { "$ref": "#/definitions/ApprovalChainStep" }
        },
        "current_step_index": { "type": "integer" },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "expired", "withdrawn"]
        },
        "context": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" },
        "decided_at": { "type": "string", "format": "date-time" },
        "timeout_hours": { "type": "integer" }
      }
    },
    "ApprovalChainStep": {
      "type": "object",
      "properties": {
        "step_index": { "type": "integer" },
        "approver_id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "skipped", "delegated"]
        },
        "decided_at": { "type": "string", "format": "date-time" },
        "decision": {
          "type": "string",
          "enum": ["approved", "rejected"]
        },
        "comments": { "type": "string" }
      }
    },
    "Escalation": {
      "type": "object",
      "required": ["id", "reporter_id", "severity", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "reporter_id": { "type": "string", "format": "uuid" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical", "p0"]
        },
        "category": {
          "type": "string",
          "enum": [
            "hallucination", "security", "financial",
            "operational", "compliance", "system"
          ]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "affected_resource": { "type": "string", "format": "uuid" },
        "affected_type": {
          "type": "string",
          "enum": ["agent", "department", "workflow", "system", "data"]
        },
        "impact_assessment": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["open", "acknowledged", "in_progress", "resolved", "closed"]
        },
        "assigned_to": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "resolution_summary": { "type": "string" }
      }
    },
    "Intervention": {
      "type": "object",
      "required": ["id", "target_id", "target_type", "action", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "issuer_id": { "type": "string", "format": "uuid" },
        "target_id": { "type": "string", "format": "uuid" },
        "target_type": {
          "type": "string",
          "enum": ["agent", "department", "workflow", "system"]
        },
        "action": {
          "type": "string",
          "enum": ["pause", "stop", "restrict", "override", "redirect", "suspend"]
        },
        "reason": { "type": "string" },
        "scope": { "type": "object" },
        "status": {
          "type": "string",
          "enum": ["active", "revoked", "auto_reverted"]
        },
        "auto_revert_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "revoked_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
