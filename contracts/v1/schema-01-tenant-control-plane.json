{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "Tenant": {
      "type": "object",
      "description": "A tenant represents a distinct customer or organization within the Operan platform, with isolated resources and configurable quotas.",
      "required": [
        "id",
        "name",
        "display_name",
        "region",
        "plan",
        "status",
        "contact_email",
        "quotas",
        "created_at",
        "updated_at",
        "isolation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the tenant, generated as a UUID v4."
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
          "minLength": 2,
          "maxLength": 63,
          "description": "DNS-safe unique name for the tenant, used as an immutable identifier in infrastructure."
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Human-readable display name for the tenant, may be updated over time."
        },
        "region": {
          "type": "string",
          "enum": [
            "me-east-1",
            "eu-west-1",
            "us-east-1",
            "ap-south-1",
            "on-prem"
          ],
          "description": "The primary cloud or on-premises region where this tenant's resources are provisioned."
        },
        "plan": {
          "type": "string",
          "enum": [
            "saas",
            "enterprise",
            "sovereign"
          ],
          "description": "The subscription plan tier determining feature access and service level."
        },
        "status": {
          "type": "string",
          "enum": [
            "provisioning",
            "active",
            "suspended",
            "deprovisioning",
            "deprovisioned"
          ],
          "description": "Current lifecycle status of the tenant."
        },
        "contact_email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the tenant administrator, used for account management and notifications."
        },
        "quotas": {
          "$ref": "#/definitions/Quota",
          "description": "Resource quotas allocated to this tenant."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the tenant was created."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last update to the tenant record."
        },
        "isolation": {
          "$ref": "#/definitions/IsolationConfig",
          "description": "Configuration specifying how this tenant's resources are isolated from others."
        }
      }
    },
    "Quota": {
      "type": "object",
      "description": "Defines the resource limits for a tenant across key dimensions such as agents, workflows, storage, and compute.",
      "required": [
        "max_agents",
        "max_workflows_per_day",
        "max_storage_gb",
        "max_monthly_tokens",
        "max_concurrent_workflows"
      ],
      "properties": {
        "max_agents": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of agents the tenant is permitted to create."
        },
        "max_workflows_per_day": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of workflows the tenant may execute per day."
        },
        "max_storage_gb": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum storage capacity in gigabytes allocated to the tenant."
        },
        "max_monthly_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of LLM tokens the tenant may consume in a monthly billing cycle."
        },
        "max_concurrent_workflows": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of workflows the tenant may run simultaneously."
        }
      }
    },
    "QuotaUsage": {
      "type": "object",
      "description": "Current resource consumption metrics for a tenant, reflecting real-time or near-real-time usage.",
      "required": [
        "active_agents",
        "workflows_today",
        "storage_gb_used",
        "tokens_this_month",
        "concurrent_workflows"
      ],
      "properties": {
        "active_agents": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of agents currently active for this tenant."
        },
        "workflows_today": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of workflows executed by this tenant today."
        },
        "storage_gb_used": {
          "type": "number",
          "minimum": 0,
          "description": "Storage consumed in gigabytes, measured to one or more decimal places."
        },
        "tokens_this_month": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of LLM tokens consumed by this tenant in the current billing month."
        },
        "concurrent_workflows": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of workflows currently running for this tenant."
        }
      }
    },
    "CreateTenantRequest": {
      "type": "object",
      "description": "Request payload for creating a new tenant on the platform.",
      "required": [
        "name",
        "region",
        "plan",
        "contact_email"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
          "minLength": 2,
          "maxLength": 63,
          "description": "DNS-safe unique name for the new tenant."
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Human-readable display name for the new tenant."
        },
        "region": {
          "type": "string",
          "enum": [
            "me-east-1",
            "eu-west-1",
            "us-east-1",
            "ap-south-1",
            "on-prem"
          ],
          "description": "The primary region where this tenant's resources will be provisioned."
        },
        "plan": {
          "type": "string",
          "enum": [
            "saas",
            "enterprise",
            "sovereign"
          ],
          "description": "The subscription plan for the new tenant."
        },
        "contact_email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the tenant administrator."
        },
        "quotas": {
          "$ref": "#/definitions/Quota",
          "description": "Custom resource quotas for the tenant. If omitted, defaults from the chosen plan apply."
        }
      }
    },
    "PatchTenantRequest": {
      "type": "object",
      "description": "Request payload for partially updating an existing tenant's attributes.",
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Updated human-readable display name for the tenant."
        },
        "contact_email": {
          "type": "string",
          "format": "email",
          "description": "Updated email address for the tenant administrator."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "suspended",
            "deprovisioning"
          ],
          "description": "New status to set for the tenant. Only these transitions are permitted via patch."
        }
      }
    },
    "UpdateQuotaRequest": {
      "type": "object",
      "description": "Request payload for updating the resource quotas of a tenant. All fields are optional; omitted fields remain unchanged.",
      "properties": {
        "max_agents": {
          "type": "integer",
          "minimum": 0,
          "description": "New maximum number of agents allowed."
        },
        "max_workflows_per_day": {
          "type": "integer",
          "minimum": 0,
          "description": "New maximum number of workflows per day allowed."
        },
        "max_storage_gb": {
          "type": "integer",
          "minimum": 0,
          "description": "New maximum storage in gigabytes allowed."
        },
        "max_monthly_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "New maximum number of LLM tokens per month allowed."
        },
        "max_concurrent_workflows": {
          "type": "integer",
          "minimum": 0,
          "description": "New maximum number of concurrent workflows allowed."
        }
      }
    },
    "IsolationConfig": {
      "type": "object",
      "description": "Configuration specifying how a tenant's resources are isolated at the namespace, encryption, and network levels.",
      "required": [
        "namespace",
        "encryption",
        "network_policy"
      ],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "Kubernetes or infrastructure namespace dedicated to this tenant's resources."
        },
        "encryption": {
          "type": "object",
          "description": "Encryption settings for data at rest for this tenant.",
          "required": [
            "algorithm",
            "key_rotation_days"
          ],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": [
                "AES-256-GCM",
                "ChaCha20-Poly1305",
                "RSA-OAEP-3072"
              ],
              "description": "Encryption algorithm used for tenant data at rest."
            },
            "key_rotation_days": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "description": "Number of days between automatic encryption key rotations."
            }
          }
        },
        "network_policy": {
          "type": "string",
          "enum": [
            "isolated",
            "restricted",
            "open"
          ],
          "description": "Network isolation level: isolated (no ingress/egress except approved), restricted (partial), or open (full)."
        }
      }
    },
    "TenantStatus": {
      "type": "object",
      "description": "Status summary for a specific tenant, suitable for health checks or operational dashboards.",
      "required": [
        "tenant_id",
        "status",
        "region"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "description": "UUID of the tenant."
        },
        "status": {
          "type": "string",
          "enum": [
            "provisioning",
            "active",
            "suspended",
            "deprovisioning",
            "deprovisioned"
          ],
          "description": "Current lifecycle status of the tenant."
        },
        "region": {
          "type": "string",
          "enum": [
            "me-east-1",
            "eu-west-1",
            "us-east-1",
            "ap-south-1",
            "on-prem"
          ],
          "description": "Region where the tenant's resources reside."
        },
        "provisioned_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the tenant reached active provisioning."
        },
        "last_activity_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last recorded activity for the tenant."
        },
        "isolation": {
          "$ref": "#/definitions/IsolationConfig",
          "description": "Current isolation configuration for the tenant."
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "description": "Standard error response structure returned by the Tenant Control Plane API on failures.",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code for programmatic handling."
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message describing what went wrong."
        },
        "details": {
          "type": "object",
          "description": "Optional structured details providing additional context about the error."
        }
      }
    },
    "BillingInvoice": {
      "type": "object",
      "description": "A billing invoice for a tenant, representing charges for a specific billing period.",
      "required": [
        "id",
        "tenant_id",
        "issue_date",
        "due_date",
        "period_start",
        "period_end",
        "currency",
        "status",
        "line_items",
        "total_amount",
        "amount_paid",
        "amount_due"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the invoice."
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the tenant this invoice is for."
        },
        "invoice_number": {
          "type": "string",
          "description": "Human-readable invoice number for reference."
        },
        "issue_date": {
          "type": "string",
          "format": "date-time",
          "description": "Date the invoice was issued."
        },
        "due_date": {
          "type": "string",
          "format": "date-time",
          "description": "Date by which payment is due."
        },
        "period_start": {
          "type": "string",
          "format": "date-time",
          "description": "Start of the billing period covered."
        },
        "period_end": {
          "type": "string",
          "format": "date-time",
          "description": "End of the billing period covered."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code (e.g., USD, EUR)."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "posted",
            "paid",
            "overdue",
            "cancelled"
          ],
          "description": "Current billing status of the invoice."
        },
        "line_items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BillingLineItem"
          },
          "description": "Individual charge line items on this invoice."
        },
        "subtotal": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of line item amounts before tax and discounts."
        },
        "tax_amount": {
          "type": "number",
          "minimum": 0,
          "description": "Tax amount applied to this invoice."
        },
        "discount_amount": {
          "type": "number",
          "minimum": 0,
          "description": "Discount amount applied to this invoice."
        },
        "total_amount": {
          "type": "number",
          "minimum": 0,
          "description": "Total amount due including tax and discounts."
        },
        "amount_paid": {
          "type": "number",
          "minimum": 0,
          "description": "Amount already paid against this invoice."
        },
        "amount_due": {
          "type": "number",
          "minimum": 0,
          "description": "Remaining amount due on this invoice."
        }
      }
    },
    "BillingLineItem": {
      "type": "object",
      "description": "A single charge line item on a billing invoice.",
      "required": [
        "description",
        "quantity",
        "unit_price",
        "total"
      ],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the charge."
        },
        "category": {
          "type": "string",
          "enum": [
            "base_subscription",
            "usage_tokens",
            "usage_storage",
            "usage_agents",
            "usage_api_calls",
            "usage_workflows",
            "overage",
            "one_time"
          ],
          "description": "Category of the charge."
        },
        "metric": {
          "type": "string",
          "description": "Specific metric billed (e.g., tokens, storage_gb, agents)."
        },
        "quantity": {
          "type": "number",
          "minimum": 0,
          "description": "Quantity consumed or charged."
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (e.g., per_1M_tokens, per_gb, per_agent)."
        },
        "unit_price": {
          "type": "number",
          "minimum": 0,
          "description": "Price per unit."
        },
        "total": {
          "type": "number",
          "minimum": 0,
          "description": "Total for this line item (quantity × unit_price)."
        }
      }
    },
    "BillingUsage": {
      "type": "object",
      "description": "Current billing period usage metrics for a tenant.",
      "required": [
        "tenant_id",
        "period",
        "period_start",
        "period_end",
        "metrics"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the tenant."
        },
        "period": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$",
          "description": "Billing period in YYYY-MM format."
        },
        "period_start": {
          "type": "string",
          "format": "date-time",
          "description": "Start of the billing period."
        },
        "period_end": {
          "type": "string",
          "format": "date-time",
          "description": "End of the billing period."
        },
        "metrics": {
          "type": "object",
          "description": "Usage metrics keyed by metric name.",
          "properties": {
            "tokens": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of LLM tokens consumed."
            },
            "workflows": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of workflows executed."
            },
            "storage_gb": {
              "type": "number",
              "minimum": 0,
              "description": "Storage consumed in gigabytes."
            },
            "agents": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of active agents."
            },
            "api_calls": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of API calls made."
            }
          }
        },
        "estimated_cost": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated cost based on current usage and pricing."
        }
      }
    },
    "PaymentMethod": {
      "type": "object",
      "description": "A payment method on file for a tenant.",
      "required": [
        "id",
        "type",
        "last_four",
        "expiry_month",
        "expiry_year",
        "brand",
        "is_default",
        "created_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the payment method record."
        },
        "type": {
          "type": "string",
          "enum": [
            "credit_card",
            "bank_account",
            "wire_transfer"
          ],
          "description": "Type of payment method."
        },
        "brand": {
          "type": "string",
          "description": "Card brand (e.g., Visa, Mastercard) for cards."
        },
        "last_four": {
          "type": "string",
          "description": "Last four digits of the card or account number."
        },
        "expiry_month": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Expiration month for cards."
        },
        "expiry_year": {
          "type": "integer",
          "minimum": 2024,
          "description": "Expiration year for cards."
        },
        "is_default": {
          "type": "boolean",
          "description": "Whether this is the default payment method."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the payment method was added."
        }
      }
    },
    "SecretMetadata": {
      "type": "object",
      "description": "Metadata for a tenant secret — value is never exposed in listing.",
      "required": [
        "id",
        "key",
        "description",
        "tags",
        "created_at",
        "updated_at",
        "version_count"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the secret."
        },
        "key": {
          "type": "string",
          "description": "Unique key name for the secret within the tenant."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the secret's purpose."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for organizing and filtering secrets."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the secret was created."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the secret metadata was updated."
        },
        "version_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of rotated versions available."
        }
      }
    },
    "Secret": {
      "type": "object",
      "description": "A single encrypted secret with its current value.",
      "required": [
        "id",
        "key",
        "value",
        "description",
        "tags",
        "created_at",
        "updated_at",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the secret."
        },
        "key": {
          "type": "string",
          "description": "Unique key name for the secret within the tenant."
        },
        "value": {
          "type": "string",
          "description": "Plaintext value of the secret (only returned on get, not on list)."
        },
        "encrypted_value": {
          "type": "string",
          "description": "Base64-encoded encrypted value for transport."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the secret's purpose."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for organizing and filtering secrets."
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Current version number (incremented on rotation)."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the secret was created."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the secret was updated or rotated."
        }
      }
    },
    "Subscription": {
      "type": "object",
      "description": "A subscription for a tenant, managing plan, billing, and lifecycle.",
      "required": [
        "id",
        "tenant_id",
        "plan",
        "status",
        "billing_cycle",
        "current_period_start",
        "current_period_end",
        "next_billing_date",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the subscription."
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the tenant this subscription belongs to."
        },
        "plan": {
          "type": "string",
          "enum": [
            "saas",
            "enterprise",
            "sovereign"
          ],
          "description": "Current subscription plan."
        },
        "plan_name": {
          "type": "string",
          "description": "Human-readable plan name (e.g., 'Enterprise Pro')."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "trialing",
            "past_due",
            "cancelled",
            "cancelling",
            "expired"
          ],
          "description": "Current status of the subscription."
        },
        "billing_cycle": {
          "type": "string",
          "enum": [
            "monthly",
            "annual",
            "quarterly"
          ],
          "description": "Billing frequency."
        },
        "seat_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of licensed seats."
        },
        "unit_price": {
          "type": "number",
          "minimum": 0,
          "description": "Price per unit per billing cycle."
        },
        "total_amount": {
          "type": "number",
          "minimum": 0,
          "description": "Total amount charged per billing cycle."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code."
        },
        "current_period_start": {
          "type": "string",
          "format": "date-time",
          "description": "Start of the current billing period."
        },
        "current_period_end": {
          "type": "string",
          "format": "date-time",
          "description": "End of the current billing period."
        },
        "next_billing_date": {
          "type": "string",
          "format": "date-time",
          "description": "Next scheduled billing date."
        },
        "cancel_at_period_end": {
          "type": "boolean",
          "description": "Whether the subscription is scheduled to cancel at period end."
        },
        "cancelled_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when cancellation was initiated."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the subscription was created."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the subscription was updated."
        },
        "custom_quotas": {
          "$ref": "#/definitions/Quota",
          "description": "Custom quotas that override the plan defaults."
        }
      }
    },
    "SubscriptionPlan": {
      "type": "object",
      "description": "A defined subscription plan with its features and pricing.",
      "required": [
        "code",
        "name",
        "tier"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "saas",
            "enterprise",
            "sovereign"
          ],
          "description": "Internal code for the plan."
        },
        "name": {
          "type": "string",
          "description": "Human-readable plan name."
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "description": "Tier level (lower number = lower tier)."
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Feature flags enabled by this plan."
        },
        "default_quotas": {
          "$ref": "#/definitions/Quota",
          "description": "Default quotas for this plan."
        },
        "base_price_monthly": {
          "type": "number",
          "minimum": 0,
          "description": "Base monthly price per unit."
        },
        "base_price_annual": {
          "type": "number",
          "minimum": 0,
          "description": "Base annual price per unit."
        },
        "usage_pricing": {
          "type": "object",
          "description": "Per-unit pricing for overage charges."
        }
      }
    }
  }
}
