{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "Workflow": {
      "type": "object",
      "required": [
        "id",
        "tenant_id",
        "workflow_name",
        "status",
        "created_by",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "workflow_name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "running",
            "paused",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "template_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "agent_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "name",
              "step_type"
            ],
            "properties": {
              "step_id": {
                "type": "string",
                "format": "uuid"
              },
              "name": {
                "type": "string"
              },
              "step_type": {
                "type": "string",
                "enum": [
                  "llm_action",
                  "tool_use",
                  "human_review",
                  "memory_access",
                  "parallel_branch"
                ]
              },
              "parameters": {
                "type": "object"
              },
              "dependencies": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "running",
                  "completed",
                  "failed",
                  "cancelled"
                ]
              }
            }
          }
        },
        "overall_status": {
          "type": "string",
          "enum": [
            "pending",
            "running",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "total_steps": {
          "type": "integer"
        },
        "completed_steps": {
          "type": "integer"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        },
        "created_by": {
          "type": "string",
          "format": "uuid"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "WorkflowStep": {
      "type": "object",
      "required": [
        "step_id",
        "name",
        "step_type",
        "status"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "step_type": {
          "type": "string",
          "enum": [
            "llm_action",
            "tool_use",
            "human_review",
            "memory_access",
            "parallel_branch"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "running",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "parameters": {
          "type": "object"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "output": {
          "type": [
            "object",
            "null"
          ]
        },
        "agent_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ]
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "CreateWorkflowRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "workflow_name"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "workflow_name": {
          "type": "string"
        },
        "template_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "agent_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "name",
              "step_type"
            ],
            "properties": {
              "step_id": {
                "type": "string",
                "format": "uuid"
              },
              "name": {
                "type": "string"
              },
              "step_type": {
                "type": "string",
                "enum": [
                  "llm_action",
                  "tool_use",
                  "human_review",
                  "memory_access",
                  "parallel_branch"
                ]
              },
              "parameters": {
                "type": "object"
              },
              "dependencies": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          }
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "CancelWorkflowRequest": {
      "type": "object",
      "required": [
        "tenant_id",
        "workflow_id"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "workflow_id": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "WorkflowEvent": {
      "type": "object",
      "required": [
        "workflow_id",
        "tenant_id",
        "event_type",
        "timestamp"
      ],
      "properties": {
        "workflow_id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "started",
            "step_started",
            "step_completed",
            "step_failed",
            "completed",
            "cancelled",
            "paused",
            "resumed"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "step_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
