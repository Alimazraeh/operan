{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operan Agent Communication & Messaging Engine Schema (Module 13)",
  "description": "Agent-to-agent messaging. Event bus, pub/sub, RPC, message routing, channel management, event schemas, and delivery guarantees.",
  "type": "object",
  "definitions": {
    "CreateChannelRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "type"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["topic", "queue", "broadcast", "rpc"]
        },
        "schema": { "type": "string" },
        "max_message_size": { "type": "integer", "default": 1048576 },
        "retention_hours": { "type": "integer", "default": 168 },
        "delivery_guarantee": {
          "type": "string",
          "enum": ["at_least_once", "at_most_once", "exactly_once"]
        },
        "priority_levels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Channel": {
      "type": "object",
      "required": ["id", "name", "type", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "schema": { "type": "string" },
        "max_message_size": { "type": "integer" },
        "retention_hours": { "type": "integer" },
        "delivery_guarantee": { "type": "string" },
        "priority_levels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "archived"]
        },
        "message_count": { "type": "integer" },
        "subscriber_count": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "UpdateChannelRequest": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "schema": { "type": "string" },
        "max_message_size": { "type": "integer" },
        "retention_hours": { "type": "integer" },
        "delivery_guarantee": {
          "type": "string",
          "enum": ["at_least_once", "at_most_once", "exactly_once"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "archived"]
        },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PublishMessageRequest": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "object" },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "critical"]
        },
        "correlation_id": { "type": "string", "format": "uuid" },
        "reply_to": { "type": "string", "format": "uuid" },
        "ttl_seconds": { "type": "integer" },
        "metadata": { "type": "object" },
        "dedup_key": { "type": "string" }
      }
    },
    "Message": {
      "type": "object",
      "required": ["id", "channel_id", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "channel_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "from_agent_id": { "type": "string", "format": "uuid" },
        "message": { "type": "object" },
        "priority": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "reply_to": { "type": "string", "format": "uuid" },
        "ttl_seconds": { "type": "integer" },
        "status": {
          "type": "string",
          "enum": [
            "published", "delivered", "acknowledged",
            "expired", "failed", "dead_letter"
          ]
        },
        "metadata": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "SubscribeRequest": {
      "type": "object",
      "required": ["agent_id"],
      "properties": {
        "agent_id": { "type": "string", "format": "uuid" },
        "filter": { "type": "object" },
        "consumer_group": { "type": "string" },
        "auto_ack": { "type": "boolean", "default": true }
      }
    },
    "Subscription": {
      "type": "object",
      "required": ["id", "channel_id", "agent_id"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "channel_id": { "type": "string", "format": "uuid" },
        "agent_id": { "type": "string", "format": "uuid" },
        "filter": { "type": "object" },
        "consumer_group": { "type": "string" },
        "auto_ack": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "error"]
        },
        "messages_consumed": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "RPCRequest": {
      "type": "object",
      "required": ["from_agent_id", "to_agent_id", "method", "payload"],
      "properties": {
        "from_agent_id": { "type": "string", "format": "uuid" },
        "to_agent_id": { "type": "string", "format": "uuid" },
        "method": { "type": "string" },
        "payload": { "type": "object" },
        "timeout_seconds": { "type": "integer", "default": 30 },
        "correlation_id": { "type": "string", "format": "uuid" },
        "ttl_seconds": { "type": "integer" }
      }
    },
    "RPCResponse": {
      "type": "object",
      "required": ["request_id"],
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "completed", "failed", "timeout", "cancelled"]
        },
        "from_agent_id": { "type": "string", "format": "uuid" },
        "to_agent_id": { "type": "string", "format": "uuid" },
        "method": { "type": "string" },
        "response": { "type": "object" },
        "error": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "RPCCancelRequest": {
      "type": "object",
      "required": ["request_id"],
      "properties": {
        "request_id": { "type": "string", "format": "uuid" }
      }
    },
    "QueueStatus": {
      "type": "object",
      "required": ["id", "name", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "error"]
        },
        "messages_total": { "type": "integer" },
        "messages_pending": { "type": "integer" },
        "messages_processed": { "type": "integer" },
        "messages_failed": { "type": "integer" },
        "subscribers": { "type": "integer" },
        "avg_processing_time_ms": { "type": "number" },
        "last_message_at": { "type": "string", "format": "date-time" }
      }
    },
    "EventPatternRequest": {
      "type": "object",
      "required": ["tenant_id", "name", "pattern"],
      "properties": {
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "pattern": {
          "type": "object",
          "properties": {
            "event_type": { "type": "string" },
            "source_agent_id": { "type": "string", "format": "uuid" },
            "tags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "filters": { "type": "object" }
          }
        },
        "target_channel_id": {
          "type": "string",
          "format": "uuid"
        },
        "target_agent_id": {
          "type": "string",
          "format": "uuid"
        },
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "EventPattern": {
      "type": "object",
      "required": ["id", "name", "pattern", "enabled"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "pattern": { "type": "object" },
        "target_channel_id": { "type": "string", "format": "uuid" },
        "target_agent_id": { "type": "string", "format": "uuid" },
        "enabled": { "type": "boolean" },
        "triggered_count": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "Delivery": {
      "type": "object",
      "required": ["id", "message_id", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "message_id": { "type": "string", "format": "uuid" },
        "channel_id": { "type": "string", "format": "uuid" },
        "recipient_agent_id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": [
            "pending", "delivered", "failed",
            "acknowledged", "dead_letter"
          ]
        },
        "delivery_attempts": { "type": "integer" },
        "last_attempt_at": { "type": "string", "format": "date-time" },
        "delivered_at": { "type": "string", "format": "date-time" },
        "error_message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "AcknowledgeMessageRequest": {
      "type": "object",
      "required": ["message_id"],
      "properties": {
        "message_id": { "type": "string", "format": "uuid" }
      }
    },
    "HealthStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy"]
        },
        "uptime_seconds": { "type": "integer" },
        "active_channels": { "type": "integer" },
        "messages_per_second": { "type": "number" },
        "queue_depth": { "type": "integer" },
        "failed_deliveries_24h": { "type": "integer" },
        "last_check": { "type": "string", "format": "date-time" }
      }
    }
  }
}
